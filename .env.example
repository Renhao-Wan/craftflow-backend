# ============================================
# CraftFlow Backend 环境变量配置模板
# ============================================
# 使用说明：
# 1. 复制此文件为 .env.dev（开发环境）或 .env（生产环境）
# 2. 填写实际的 API Key 和配置信息
# 3. 切勿将包含真实密钥的 .env 文件提交到 Git

# ============================================
# 应用基础配置
# ============================================
APP_NAME="CraftFlow Backend"
APP_VERSION="0.1.0"
ENVIRONMENT="development"  # development / production
DEBUG=true
LOG_LEVEL="INFO"  # DEBUG / INFO / WARNING / ERROR

# ============================================
# LLM 配置
# ============================================

# ============================================
# LLM 配置
# ============================================
# LLM API 配置
LLM_API_KEY="sk-your-openai-api-key-here"
LLM_API_BASE=""
LLM_MODEL="gpt-4-turbo"
MAX_TOKENS=4096

# LLM 差异参数
DEFAULT_TEMPERATURE=0.7
EDITOR_NODE_TEMPERATURE=0.2

# ============================================
# 状态持久化配置
# ============================================
# 是否使用持久化 Checkpointer（false 使用 MemorySaver，true 使用 PostgresSaver）
USE_PERSISTENT_CHECKPOINTER=false

# PostgreSQL 配置（生产环境必填）
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/craftflow"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# 外部工具 API 配置
# ============================================
# Tavily Search API（互联网搜索）
TAVILY_API_KEY="tvly-your-tavily-api-key-here"

# E2B Code Interpreter（代码沙箱）
E2B_API_KEY="your-e2b-api-key-here"

# ============================================
# LangSmith 追踪配置（可选）
# ============================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your-langsmith-api-key-here"
LANGCHAIN_PROJECT="craftflow-backend"

# ============================================
# FastAPI 服务配置
# ============================================
HOST="0.0.0.0"
PORT=8000
RELOAD=true  # 开发环境热重载
WORKERS=1  # 生产环境建议设置为 CPU 核心数

# CORS 配置
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"  # 前端地址，逗号分隔
CORS_ALLOW_CREDENTIALS=true  # 是否允许携带 Cookie 等凭证

# ============================================
# Redis 配置（可选，用于限流和缓存）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ============================================
# 业务逻辑配置
# ============================================
# 创作流配置
MAX_OUTLINE_SECTIONS=10  # 大纲最大章节数
MAX_CONCURRENT_WRITERS=5  # 并发写作节点数量上限

# 润色流配置
MAX_DEBATE_ITERATIONS=3  # 对抗循环最大迭代次数
EDITOR_PASS_SCORE=90  # 主编通过分数阈值

# 任务超时配置（秒）
TASK_TIMEOUT=3600  # 1小时
TOOL_CALL_TIMEOUT=30  # 工具调用超时
